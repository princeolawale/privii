# Vercel KV REST endpoint URL for @vercel/kv reads and writes.
KV_REST_API_URL=

# Vercel KV REST token for @vercel/kv authentication.
KV_REST_API_TOKEN=

# Optional: override the Solana RPC endpoint used by the app.
NEXT_PUBLIC_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY=https://api.mainnet-beta.solana.com

# Reown AppKit project id used for the unified multichain wallet modal.
NEXT_PUBLIC_REOWN_PROJECT_ID=
